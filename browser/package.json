{
  "name": "ink-storylet-framework",
  "version": "0.0.8",
  "description": "A simple storylet framework for Ink.",
  "main": "./build/cjs/StoryletManager.js",
  "module": "./build/es/StoryletManager.js",
  "types": "./build/es/StoryletManager.d.ts",
  "exports": {
    ".": {
      "types": "./build/es/StoryletManager.d.ts",
      "require": "./build/cjs/StoryletManager.js",
      "import": "./build/es/StoryletManager.js",
      "default": "./build/es/StoryletManager.js"
    },
    "./runner": {
      "types": "./build/es/StoryletRunner.d.ts",
      "require": "./build/cjs/StoryletRunner.js",
      "import": "./build/es/StoryletRunner.js",
      "default": "./build/es/StoryletRunner.js"
    }
  },
  "files": [
    "build",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "npx vite test-harness",
    "map-test": "npx vite map-test",
    "build": "rm -rf build && vite build && cp ../README.md . && cp ../LICENSE ."
  },
  "dependencies": {
    "inkjs": "^2.3.2",
    "inklecate": "^1.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
